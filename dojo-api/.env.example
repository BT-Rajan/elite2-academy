# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# ── Database ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=dojo_platform
DB_USER=root
DB_PASS=

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING_BEFORE_USE
JWT_EXPIRY=3600

# ── App ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:4200
# Comma-separated list of origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:4200

MAIL_FROM=noreply@yourdojo.com
MAIL_FROM_NAME="Dojo Platform"

# ── Login rate limiting ──────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── User-facing error messages ───────────────────────────────────────────
# Anything NOT set here falls back to a sane built-in default
# (see core/ErrorMessages.php). Raw exception/DB details are never sent
# to the client — only these messages are, and the real error is
# written to the PHP error log instead.
ERR_AUTH_INVALID_CREDENTIALS="Invalid email or password."
ERR_AUTH_TOKEN_REQUIRED="Please sign in to continue."
ERR_AUTH_PENDING_APPROVAL="Your account is pending approval. You'll get access once an administrator approves it."
ERR_AUTH_REJECTED="Your account request was not approved. Contact your dojo administrator."
ERR_AUTH_FORBIDDEN="You don't have permission to do that."
ERR_AUTH_RATE_LIMITED="Too many sign-in attempts. Please try again in a few minutes."
ERR_AUTH_INVALID_TOKEN="Your session is no longer valid. Please sign in again."
ERR_SERVER_GENERIC="Something went wrong on our end. Please try again."
ERR_SERVER_DATABASE="We couldn't complete that request right now. Please try again shortly."
ERR_VALIDATION_GENERIC="Please check your input and try again."
