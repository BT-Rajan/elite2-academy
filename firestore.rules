rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isAuth()           { return request.auth != null; }
    function uid()              { return request.auth.uid; }
    function userDoc()          { return get(/databases/$(database)/documents/users/$(uid())); }
    function role()             { return userDoc().data.role; }
    function dojoId()           { return userDoc().data.dojoId; }
    function isAdmin()          { return role() == 'admin'; }
    function isCoach()          { return role() == 'coach' || isAdmin(); }
    function isParent()         { return role() == 'parent'; }
    function inDojo(id)         { return dojoId() == id; }
    function owns(field)        { return resource.data[field] == uid(); }
    function incoming(field)    { return request.resource.data[field]; }
    function notChanging(field) { return !(field in request.resource.data.diff(resource.data).affectedKeys()); }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isCoach());
      allow create: if isAuth() && uid() == userId
                    && incoming('role') in ['parent','coach','admin'];
      allow update: if isAuth() && uid() == userId && notChanging('role')
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Dojos ─────────────────────────────────────────────────────────────────
    match /dojos/{dojoId} {
      allow read:  if isAuth() && inDojo(dojoId);
      allow write: if isAuth() && isAdmin() && inDojo(dojoId);

      match /dailyReports/{reportId} {
        allow read:  if isAuth() && (isAdmin() || isCoach()) && inDojo(dojoId);
        allow write: if false; // written only by Cloud Functions
      }
    }

    // ── Disciplines ───────────────────────────────────────────────────────────
    match /disciplines/{discId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();

      match /belts/{beltId} {
        allow read:  if isAuth();
        allow write: if isAuth() && isAdmin();
      }
    }

    // ── Schedules (public read) ───────────────────────────────────────────────
    match /schedules/{schedId} {
      allow read:  if true;  // public — needed for the public schedule page
      allow write: if isAuth() && (isAdmin() || isCoach());
    }

    // ── Students ──────────────────────────────────────────────────────────────
    match /students/{studentId} {
      allow read:   if isAuth() && (isCoach() || owns('parentUid'));
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && (isAdmin() || isCoach()) && notChanging('parentUid');
      allow delete: if isAdmin();

      match /beltHistory/{histId} {
        allow read:   if isAuth() && (isCoach() || get(/databases/$(database)/documents/students/$(studentId)).data.parentUid == uid());
        allow create: if isAuth() && isCoach();
        allow update, delete: if isAdmin();
      }

      match /objectives/{objId} {
        allow read:   if isAuth() && (isCoach() || get(/databases/$(database)/documents/students/$(studentId)).data.parentUid == uid());
        allow create: if isAuth() && isCoach();
        allow update: if isAuth() && isCoach();
        allow delete: if isAdmin();
      }
    }

    // ── Sessions ──────────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:   if isAuth() && (isCoach() || isParent());
      allow create: if isAuth() && isCoach();
      allow update: if isAuth() && isCoach() && owns('coachUid');
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read:   if isAuth();
        allow create: if isAuth() && isCoach();
        allow update: if isAuth() && isCoach() && owns('coachUid');
        allow delete: if isAdmin();
      }
    }

    // ── Attendance ────────────────────────────────────────────────────────────
    match /attendance/{recordId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isCoach();
      allow update: if isAuth() && isCoach();
      allow delete: if isAdmin();
    }

    // ── Threads & Messages ────────────────────────────────────────────────────
    match /threads/{threadId} {
      function threadData() { return get(/databases/$(database)/documents/threads/$(threadId)).data; }
      function inThread()   { return threadData().coachUid == uid() || threadData().parentUid == uid(); }

      allow read:   if isAuth() && inThread();
      allow create: if isAuth() && isCoach();
      allow update: if isAuth() && inThread();
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read:   if isAuth() && inThread();
        allow create: if isAuth() && inThread() && incoming('fromUid') == uid();
        allow update, delete: if false; // messages are immutable
      }
    }

    // ── Loyalty ───────────────────────────────────────────────────────────────
    match /loyalty/{parentId} {
      allow read:  if isAuth() && (uid() == parentId || isCoach());
      allow write: if false; // written only by Cloud Functions

      match /transactions/{txId} {
        allow read:  if isAuth() && (uid() == parentId || isCoach());
        allow write: if false; // written only by Cloud Functions
      }
    }

    match /loyalty_rewards/{rewardId} {
      allow read:  if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && owns('uid');
      allow update: if isAuth() && owns('uid')
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead','readAt']);
      allow write:  if false; // created only by Cloud Functions
    }

    // ── FCM Tokens ────────────────────────────────────────────────────────────
    match /fcmTokens/{userId} {
      allow read, write: if isAuth() && uid() == userId;
    }

    // ── Stripe Customers ──────────────────────────────────────────────────────
    match /customers/{userId} {
      allow read:  if isAuth() && (uid() == userId || isAdmin());
      allow write: if false; // written only by Cloud Functions

      match /checkout_sessions/{sessionId} {
        allow read, create: if isAuth() && uid() == userId;
        allow update, delete: if false;
      }
    }
  }
}
